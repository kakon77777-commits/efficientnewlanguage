# Phase 7e: class — minimal viable OOP (no inheritance, no dunders beyond __init__).
class Counter:
    def __init__(self, start):
        start => self.value
    def increment(self):
        self.value + 1 => self.value
    def get(self):
        return self.value

Counter(0) => c
c.increment()
c.increment()
c.get() => result
result^0
